#!/usr/bin/env bash
# 此脚本用于拦截把普通轻量标签(Lightweight Tag)推送到远程的情况

while read local_ref local_sha remote_ref remote_sha
do
    # 检查是否是在推送一个 Tag
    if [[ "$remote_ref" == refs/tags/* ]]; then
        # 防止删除标签操作也被拦截 (全零SHA代表删除)
        if [ "$local_sha" != "0000000000000000000000000000000000000000" ]; then
            # 检查这是一个什么类型的本地对象 (只有附注标签 Annotated tag 返回的结果是 tag，普通标签返回的是 commit)
            object_type=$(git cat-file -t "$local_sha" 2>/dev/null)
            
            if [ "$object_type" != "tag" ]; then
                echo -e "\033[31m"
                echo "============================================="
                echo "🛑 警报！！(￣▽￣)\""
                echo "你正在尝试推送一个普通的轻量标签：$remote_ref"
                echo "是不是你或者 AI 忘记写更新内容啦喵？"
                echo ""
                echo "如果就这样推送上去，GitHub Actions 的打包任务会报错哦！"
                echo "请在本地偷偷把它删掉 (git tag -d 标签名) 毁灭证据，"
                echo "然后重新打带说明的标签："
                echo "git tag -a 标签名 -m \"1. 更新了xxx ; 2. 修复了xxx\""
                echo "然后再推送吧！(≧∇≦)ﾉ"
                echo "============================================="
                echo -e "\033[0m"
                exit 1
            fi

            # 获取标签的内容并检测是否包含中文字符
            tag_message=$(git tag -l --format='%(contents)' "${remote_ref#refs/tags/}")
            if ! echo "$tag_message" | grep -qP '[\x{4e00}-\x{9fa5}]'; then
                echo -e "\033[31m"
                echo "============================================="
                echo "🛑 语言警报！！(￣▽￣)\""
                echo "你正在推送的标签：${remote_ref#refs/tags/} 里面没有任何中文！"
                echo "一定是刚刚那个笨蛋 AI 图省事，全给你写成英文了吧？！"
                echo ""
                echo "根据最高指示，我们的更新日志必须是纯正的【简体中文】！"
                echo "请狠心在本地删掉它 (git tag -d 标签名) 然后重写一遍吧喵~"
                echo "============================================="
                echo -e "\033[0m"
                exit 1
            fi
        fi
    fi
done

exit 0
